generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Volunteer {
  id                  String          @id @default(uuid())
  volunteerCode       String          @unique // e.g., VOL-12345
  email               String          @unique
  phone               String          @unique
  passwordHash        String
  collegeProofUrl     String          
  livePhotoUrl        String          
  isApproved          Boolean         @default(false) 
  certifications      Certification[]
  usersAssigned       User[]          
  createdAt           DateTime        @default(now())
}

model Certification {
  id           String    @id @default(uuid())
  certCode     String    @unique // e.g., CERT-12345
  title        String
  hoursValue   Int       
  proofUrl     String?   
  volunteerId  String
  volunteer    Volunteer @relation(fields: [volunteerId], references: [id])
  issuedAt     DateTime  @default(now())
}

model User {
  id                  String     @id @default(uuid())
  userCode            String     @unique // e.g., USR-12345
  phone               String     @unique
  otp                 String?    
  otpExpiry           DateTime?
  scoreRating         Int        @default(0) 
  hasWatchedTutorial  Boolean    @default(false) // Tracks if they've seen the onboarding video
  encryptedVideoUrl   String?    
  associatedVolId     String?
  associatedVolunteer Volunteer? @relation(fields: [associatedVolId], references: [id])
  createdAt           DateTime   @default(now())
}
